#!/usr/bin/env bash
# icc claude wrapper - injects hooks and session tracking
#
# When running inside a icc terminal (ICC_SURFACE_ID is set), this wrapper
# intercepts `claude` invocations to inject --session-id and --settings flags
# so that Claude Code hooks fire back into icc for notifications/status.
# Outside icc, it passes through to the real claude binary unchanged.

# Find the real claude binary, skipping our own directory.
find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Return 0 only when ICC_SOCKET_PATH points to a live icc socket.
icc_socket_available() {
    local socket="${ICC_SOCKET_PATH:-}"
    [[ -n "$socket" && -S "$socket" ]] || return 1

    local self_dir icc_bin
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    icc_bin="$self_dir/icc"
    [[ -x "$icc_bin" ]] || icc_bin="$(command -v icc || true)"
    [[ -n "$icc_bin" ]] || return 1

    # Keep stale/hung socket checks bounded so claude startup does not block
    # behind the CLI default timeout (15s).
    ICC_CLI_RESPONSE_TIMEOUT_SEC=0.75 \
        "$icc_bin" --socket "$socket" ping >/dev/null 2>&1
}

# Pass through if not in a icc terminal, hooks are disabled, or the icc
# socket is unavailable (stale env / app not running).
IN_ICC=0
if [[ -n "$ICC_SURFACE_ID" ]]; then
    IN_ICC=1
fi

if [[ "$IN_ICC" == "0" || "$ICC_CLAUDE_HOOKS_DISABLED" == "1" ]] || ! icc_socket_available; then
    # In icc-launched shells, preserve old behavior and always clear nested
    # Claude session markers, even when we must pass through due to stale socket.
    if [[ "$IN_ICC" == "1" ]]; then
        unset CLAUDECODE
    fi
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

# Find real claude.
REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through subcommands that don't support session/hook flags.
case "${1:-}" in
    mcp|config|api-key|rc|remote-control) exec "$REAL_CLAUDE" "$@" ;;
esac

# Unset CLAUDECODE to avoid "nested session" detection — icc terminals are
# independent sessions even when the parent shell was launched from Claude Code.
unset CLAUDECODE

# Check if the user already specified a session/resume flag.
# If so, don't inject our own --session-id (it would conflict).
SKIP_SESSION_ID=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|--session-id|--session-id=*|--continue|-c)
            SKIP_SESSION_ID=true
            break
            ;;
    esac
done

# Export the wrapper's PID. Because we exec claude below, this PID becomes
# the actual claude process PID, which hooks use for stale-session detection.
export ICC_CLAUDE_PID=$$

# Build hooks settings JSON.
# Claude Code merges --settings additively with the user's own settings.json.
# - SessionStart/Stop/Notification: existing lifecycle hooks
# - SessionEnd: cleanup when Claude exits (covers Ctrl+C where Stop doesn't fire)
# - UserPromptSubmit: clears "Needs input" and sets "Running" on new prompt
# - PreToolUse: clears "Needs input" when Claude resumes after permission grant (async to avoid latency)
HOOKS_JSON='{"hooks":{"SessionStart":[{"matcher":"","hooks":[{"type":"command","command":"icc claude-hook session-start","timeout":10}]}],"Stop":[{"matcher":"","hooks":[{"type":"command","command":"icc claude-hook stop","timeout":10}]}],"SessionEnd":[{"matcher":"","hooks":[{"type":"command","command":"icc claude-hook session-end","timeout":1}]}],"Notification":[{"matcher":"","hooks":[{"type":"command","command":"icc claude-hook notification","timeout":10}]}],"UserPromptSubmit":[{"matcher":"","hooks":[{"type":"command","command":"icc claude-hook prompt-submit","timeout":10}]}],"PreToolUse":[{"matcher":"","hooks":[{"type":"command","command":"icc claude-hook pre-tool-use","timeout":5,"async":true}]}]}}'

if [[ "$SKIP_SESSION_ID" == true ]]; then
    exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
else
    SESSION_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    exec "$REAL_CLAUDE" --session-id "$SESSION_ID" --settings "$HOOKS_JSON" "$@"
fi
